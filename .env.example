# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mental-wellbeing-app

# AI Service Providers (Configure at least one)
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (for local AI models)
OLLAMA_URL=http://localhost:11434

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_complex

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password

# Application Settings
APP_NAME=Mansarthi - AI Mental Wellness
APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@yourdomain.com

# Rate Limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# AI Configuration
AI_RESPONSE_TIMEOUT=10000
AI_MAX_TOKENS=300
AI_TEMPERATURE=0.7

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_CRISIS_SUPPORT=true
ENABLE_COMMUNITY_FEATURES=true
ENABLE_ANALYTICS=false