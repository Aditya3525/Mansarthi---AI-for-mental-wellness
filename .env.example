# Environment Configuration for Mansarthi Mental Wellness Platform

# ================================
# DATABASE CONFIGURATION
# ================================

# MongoDB connection string
# For local development: mongodb://localhost:27017/mental-wellbeing-app
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mental-wellbeing-app
MONGODB_URI=mongodb://localhost:27017/mental-wellbeing-app

# ================================
# AI SERVICE CONFIGURATION
# ================================

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Configuration  
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (for local AI)
# Default local Ollama installation URL
OLLAMA_URL=http://localhost:11434

# ================================
# SERVER CONFIGURATION
# ================================

# Port for the Express server
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ================================
# SECURITY CONFIGURATION
# ================================

# JWT Secret for token signing (generate a secure random string)
JWT_SECRET=your_super_secure_jwt_secret_here

# Session secret for Express sessions
SESSION_SECRET=your_session_secret_here

# ================================
# OPTIONAL FEATURES
# ================================

# Email service configuration (for notifications)
# EMAIL_SERVICE=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Redis URL (for session storage and caching)
# REDIS_URL=redis://localhost:6379

# Sentry DSN (for error monitoring)
# SENTRY_DSN=your_sentry_dsn_here

# ================================
# DEVELOPMENT CONFIGURATION
# ================================

# Enable debug logging
DEBUG=false

# Enable AI service debug
AI_DEBUG=false

# Enable database query logging
DB_DEBUG=false

# ================================
# DEPLOYMENT CONFIGURATION
# ================================

# Base URL for the application (used in emails, redirects)
BASE_URL=http://localhost:3000

# CORS allowed origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ================================
# RATE LIMITING
# ================================

# API rate limits (requests per minute)
API_RATE_LIMIT=100
CHAT_RATE_LIMIT=20
ASSESSMENT_RATE_LIMIT=50

# ================================
# NOTES FOR SETUP
# ================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (remove placeholders)
# 3. Never commit the .env file to version control
# 4. For production, use environment variables instead of .env file
# 5. Obtain AI API keys only if you want enhanced AI features
# 6. The application will work with fallback responses if no AI keys are provided